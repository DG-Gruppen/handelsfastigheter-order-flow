{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lucaid.local/schema.json",
  "title": "LucAId Manifest Schema",
  "type": "object",
  "required": [
    "package",
    "conventions",
    "verified_context",
    "documents",
    "impact_map",
    "self_validation"
  ],
  "properties": {
    "package": {
      "type": "object",
      "required": [
        "name",
        "version",
        "repository",
        "system",
        "generated_at",
        "entry_points"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^(\\d+\\.\\d+\\.\\d+|\\{\\{[^}]+\\}\\})$"
        },
        "repository": {
          "type": "string"
        },
        "system": {
          "type": "string"
        },
        "default_branch": {
          "type": "string"
        },
        "generated_at": {
          "type": "string",
          "pattern": "^(\\d{4}-\\d{2}-\\d{2}|\\{\\{[^}]+\\}\\})$"
        },
        "entry_points": {
          "type": "object",
          "required": [
            "human",
            "full_analysis",
            "pr_audit"
          ],
          "properties": {
            "human": {
              "type": "string"
            },
            "full_analysis": {
              "type": "string"
            },
            "pr_audit": {
              "type": "string"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "conventions": {
      "type": "object",
      "required": [
        "doc_status",
        "evidence_labels",
        "severity",
        "escalation_levels"
      ]
    },
    "verified_context": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "title",
          "role",
          "status",
          "source_of_truth",
          "owner",
          "depends_on",
          "used_by",
          "update_triggers"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "path": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "status": {
            "enum": [
              "Draft",
              "Active",
              "Deprecated"
            ]
          },
          "source_of_truth": {
            "type": "boolean"
          },
          "owner": {
            "type": "string"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "used_by": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "update_triggers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "impact_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "patterns",
          "review_docs",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "patterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "review_docs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "self_validation": {
      "type": "object"
    }
  }
}