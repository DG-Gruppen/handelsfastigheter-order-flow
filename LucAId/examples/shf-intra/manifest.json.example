  "impact_map": [
    {
      "id": "auth_permissions",
      "patterns": [
        "^src/hooks/(useAuth|useModules|useAdminAccess|useModulePermission|useNavSettings)",
        "^src/components/ProtectedRoute"
      ],
      "review_docs": [
        "docs/core/PERMISSION_MODEL.md",
        "docs/core/ARCHITECTURE.md",
        "docs/governance/KNOWN_RISKS.md",
        "docs/governance/CHANGE_SAFETY_RULES.md"
      ],
      "notes": [
        "Verify server-side role enforcement and module access assumptions."
      ]
    },
    {
      "id": "order_flows",
      "patterns": [
        "^src/pages/(NewOrder|OrderDetail|History)"
      ],
      "review_docs": [
        "docs/core/DOMAIN_RULES.md",
        "docs/core/WORKFLOW_MAPS.md",
        "docs/governance/KNOWN_RISKS.md",
        "docs/governance/CHANGE_SAFETY_RULES.md"
      ],
      "notes": [
        "Check approval routing, lifecycle transitions, side effects, and multi-step writes."
      ]
    },
    {
      "id": "documents",
      "patterns": [
        "^src/pages/Documents",
        "^src/hooks/useDocuments"
      ],
      "review_docs": [
        "docs/core/DOMAIN_RULES.md",
        "docs/core/WORKFLOW_MAPS.md",
        "docs/governance/KNOWN_RISKS.md",
        "docs/reference/CODEBASE_GLOSSARY.md",
        "docs/governance/CHANGE_SAFETY_RULES.md"
      ],
      "notes": [
        "Review folder access roles, write roles, recursive access, and bucket RLS."
      ]
    },
    {
      "id": "passwords",
      "patterns": [
        "^src/pages/Passwords",
        "^src/lib/passwordCrypto",
        "^supabase/functions/get-passwords-key"
      ],
      "review_docs": [
        "docs/core/DOMAIN_RULES.md",
        "docs/core/ARCHITECTURE.md",
        "docs/governance/KNOWN_RISKS.md",
        "docs/governance/CHANGE_SAFETY_RULES.md"
      ],
      "notes": [
        "Review AES key issuance, group membership checks, and access logging."
      ]
    },
    {
      "id": "planner",
      "patterns": [
        "^src/pages/Planner",
        "^src/components/.*/Planner",
        "^src/lib/.*/planner"
      ],
      "review_docs": [
        "docs/core/DOMAIN_RULES.md",
        "docs/core/WORKFLOW_MAPS.md",
        "docs/governance/CHANGE_SAFETY_RULES.md"
      ],
      "notes": [
        "Check drag-and-drop integrity, comments, attachments, and activity log writes."
      ]
    },
    {
      "id": "admin",
      "patterns": [
        "^src/pages/Admin",
        "^src/hooks/useAdminAccess"
      ],
      "review_docs": [
        "docs/core/PERMISSION_MODEL.md",
        "docs/governance/KNOWN_RISKS.md",
        "docs/governance/CHANGE_SAFETY_RULES.md"
      ],
      "notes": [
        "Admin visibility is not proof of backend authority."
      ]
    },
    {
      "id": "backend",
      "patterns": [
        "^supabase/functions/",
        "^supabase/migrations/"
      ],
      "review_docs": [
        "docs/core/ARCHITECTURE.md",
        "docs/core/DOMAIN_RULES.md",
        "docs/governance/KNOWN_RISKS.md",
        "docs/governance/CHANGE_SAFETY_RULES.md",
        "docs/reference/CODEBASE_GLOSSARY.md"
      ],
      "notes": [
        "State whether the change closes, widens, or is unrelated to any open risk."
      ]
    },
    {
      "id": "app_shell",
      "patterns": [
        "^src/(App|main)\\.(tsx|ts)$"
      ],
      "review_docs": [
        "docs/core/ARCHITECTURE.md",
        "docs/core/PERMISSION_MODEL.md",
        "docs/governance/CHANGE_SAFETY_RULES.md"
      ],
      "notes": [
        "Review routing, session rehydration, and module load ordering."
      ]
    },
    {
      "id": "email_notifications",
      "patterns": [
        "^src/lib/(orderEmails|sendHelpdeskEmail|emailTemplates)",
        "^supabase/functions/(process-email-queue|send-email)"
      ],
      "review_docs": [
        "docs/core/DOMAIN_RULES.md",
        "docs/core/WORKFLOW_MAPS.md",
        "docs/governance/KNOWN_RISKS.md",
        "docs/governance/CHANGE_SAFETY_RULES.md"
      ],
      "notes": [
        "Review queue writes, dead-letter handling, and idempotency."
      ]
    },
    {
      "id": "ai_content",
      "patterns": [
        "^supabase/functions/(ai-chat|sync-content-index|scrape-)"
      ],
      "review_docs": [
        "docs/core/ARCHITECTURE.md",
        "docs/core/DOMAIN_RULES.md",
        "docs/governance/KNOWN_RISKS.md",
        "docs/governance/CHANGE_SAFETY_RULES.md"
      ],
      "notes": [
        "Review content index access filters, prompt boundaries, and data exposure."
      ]
    },
    {
      "id": "system_docs",
      "patterns": [
        "^docs/SYSTEM_OVERVIEW\\.md",
        "^manifest\\.json",
        "^schema\\.json"
      ],
      "review_docs": [
        "docs/core/AI_ANALYSIS.md",
        "docs/core/ARCHITECTURE.md",
        "docs/core/DOMAIN_RULES.md",
        "docs/core/PERMISSION_MODEL.md",
        "docs/core/WORKFLOW_MAPS.md",
        "docs/governance/DOC_OWNERSHIP_RULES.md",
        "docs/governance/SELF_VALIDATION_RULES.md",
        "docs/reference/CODEBASE_GLOSSARY.md",
        "docs/governance/CHANGE_SAFETY_RULES.md",
        "docs/reference/DATA_MODEL.md"
      ],
      "notes": [
        "Review package-wide consistency and control-plane drift."
      ]
    }
  ],
  "self_validation": {
    "rules_doc": "docs/governance/SELF_VALIDATION_RULES.md",
    "required_root_files": [
      "VERSION",
      "CHANGELOG.md",
      "manifest.json",
      "schema.json"
    ],
    "required_metadata_fields": [
      "Repository",
      "System",
      "Package Version",
      "Status",
      "Source of Truth",
      "Depends On",
      "Used By",
      "Owner",
      "Update Triggers"
    ],
    "rules": [
      "every_document_exists",
      "unique_document_ids",
      "verified_context_paths_exist",
      "dependencies_resolve",
      "source_of_truth_roles_are_unique",
      "version_consistency",
      "entry_points_exist",
      "impact_map_docs_exist",
      "impact_map_patterns_compile",
      "schema_enforcement",
      "enum_severity_conformance",
      "enum_escalation_conformance",
      "crossdoc_glossary_coverage",
      "crossdoc_risk_ids",
      "crossdoc_impact_domain_coverage"
    ],
    "validation_layers": 8
  }
}